# Copy this file to ".env" and fill in the values from your Firebase project.
# Firebase Console → Project Settings → General → "Your apps" → SDK setup and configuration
#
# These values are safe to expose in client-side code (Firebase config is not a secret),
# but keeping them in .env keeps dev/staging/prod projects easy to swap without touching code.
#
# DEPLOYING ON NETLIFY: .env is not uploaded to Netlify (it's gitignored).
# Add these same six values in Netlify → Site settings → Environment variables,
# using the exact same VITE_ prefixed names, so they're available at build time.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
